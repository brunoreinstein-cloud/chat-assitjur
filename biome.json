{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": false,
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "!!.pnpm-store",
      "!!**/.pnpm-store",
      "!!.next",
      "!!**/.next",
      "!!.agents",
      "!!.vercel",
      "!!.vscode",
      "!!.claude",
      "!!**/.claude",
      "!!vercel.json",
      "!!**/test-results",
      "!!**/playwright-report",
      "!!**/blob-report",
      "!!**/.playwright"
    ]
  },
  "css": { "parser": { "tailwindDirectives": true } },
  "linter": {
    "rules": {
      "performance": {
        "useTopLevelRegex": "off",
        "noNamespaceImport": "off"
      },
      "style": { "noNestedTernary": "off" },
      "complexity": { "noExcessiveCognitiveComplexity": "off" },
      "correctness": { "useImageSize": "off" },
      "a11y": { "noNoninteractiveElementInteractions": "off" }
    }
  },
  "overrides": [
    {
      "includes": ["components/ui/carousel.tsx"],
      "linter": { "rules": { "a11y": { "useSemanticElements": "off" } } }
    },
    {
      "includes": ["components/knowledge-sidebar.tsx"],
      "linter": {
        "rules": {
          "security": { "noDangerouslySetInnerHtml": "off" }
        }
      }
    }
  ]
}
