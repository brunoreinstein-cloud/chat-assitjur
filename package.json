{
  "name": "chatbot",
  "version": "3.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next dev --turbo -p 3300",
    "dev:test": "cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next dev --turbo",
    "dev:warmup": "node scripts/dev-warmup.js",
    "prebuild": "pnpm run lint && pnpm run test:unit",
    "build": "pnpm run prebuild && tsx lib/db/migrate && cross-env BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next build",
    "start": "next start",
    "check": "pnpm run lint && pnpm exec tsc --noEmit",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "_db:seed-redator-banco": "tsx scripts/seed-redator-banco.ts",
    "_db:add-agent-id": "tsx scripts/db-add-agent-id.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "node -e \"console.warn('Use pnpm db:migrate para aplicar o schema. drizzle-kit push falha com colunas sem default (bug).');\"",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:ping": "tsx scripts/db-ping.ts",
    "db:tables": "tsx scripts/db-tables.ts",
    "db:up": "drizzle-kit up",
    "_supabase:link": "npx supabase link",
    "_supabase:start": "npx supabase start",
    "_supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:types": "npx supabase gen types typescript --linked > lib/db/supabase-types.ts",
    "_supabase:config-push": "npx supabase config push",
    "_supabase:api-keys": "npx supabase projects api-keys -o env",
    "_supabase:env": "tsx scripts/supabase-env.ts",
    "_supabase:setup": "pnpm run _supabase:config-push",
    "_vercel:link": "npx vercel link",
    "_vercel:pull": "npx vercel pull",
    "vercel:env": "npx vercel env pull .env.local",
    "vercel:env:prod": "npx vercel env pull .env.local --environment=production --yes",
    "vercel:env:push": "tsx scripts/vercel-env-push.ts",
    "vercel:review": "tsx scripts/vercel-review-env.ts",
    "vercel:deploy": "npx vercel",
    "vercel:deploy:prod": "npx vercel --prod --yes --archive=tgz",
    "_vercel:open": "npx vercel open",
    "skills:check": "npx skills check",
    "skills:list": "npx skills list",
    "vercel:logs": "npx vercel logs",
    "_predeploy": "tsx scripts/pre-deploy.ts",
    "prepush": "pnpm run build",
    "_config:check": "tsx scripts/check-config.ts",
    "_health:ai": "tsx scripts/check-ai-connection.ts",
    "_benchmark:llm": "tsx scripts/benchmark-llm.ts",
    "analyze": "tsx lib/db/migrate && cross-env ANALYZE=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next build --webpack",
    "test": "cross-env PLAYWRIGHT=True PLAYWRIGHT_USE_WEB_SERVER=1 pnpm exec playwright test",
    "test:with-warmup": "pnpm db:ping && pnpm test",
    "_test:report": "pnpm exec playwright show-report",
    "test:with-dev": "cross-env PLAYWRIGHT=True PLAYWRIGHT_TEST_BASE_URL=http://localhost:3300 pnpm exec playwright test",
    "_test:with-dev-3301": "cross-env PLAYWRIGHT=True PLAYWRIGHT_TEST_BASE_URL=http://localhost:3301 pnpm exec playwright test",
    "_validate:prompt": "tsx lib/prompts/agente-trabalhista/run-validate.ts",
    "test:unit": "pnpm exec vitest run",
    "test:coverage": "pnpm exec vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.63",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/react": "3.0.113",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@napi-rs/canvas": "^0.1.95",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.200.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/functions": "^2.2.13",
    "@vercel/otel": "^1.14.0",
    "@xyflow/react": "^12.10.1",
    "ai": "6.0.111",
    "bcrypt-ts": "^5.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "fast-deep-equal": "^3.1.3",
    "geist": "^1.7.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.576.0",
    "mammoth": "^1.12.0",
    "motion": "^12.34.5",
    "nanoid": "^5.1.6",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "orderedmap": "^2.1.1",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "postgres": "^3.4.8",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-data-grid": "7.0.0-beta.47",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^2.1.9",
    "react-syntax-highlighter": "^15.6.6",
    "redis": "^5.11.0",
    "resumable-stream": "^2.2.10",
    "server-only": "^0.0.1",
    "shiki": "^3.23.0",
    "sonner": "^1.7.4",
    "streamdown": "^2.3.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "usehooks-ts": "^3.1.1",
    "word-extractor": "^1.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@biomejs/biome": "2.4.5",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^22.19.13",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/word-extractor": "^1.0.6",
    "@vitest/coverage-v8": "^2.1.9",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.4",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "patchedDependencies": {
      "ultracite@7.2.4": "patches/ultracite@7.2.4.patch"
    },
    "overrides": {
      "next-auth>next": "$next",
      "next-themes>react": "$react",
      "next-themes>react-dom": "$react-dom",
      "undici": ">=6.24.0",
      "prismjs": ">=1.30.0",
      "esbuild": ">=0.25.0"
    }
  }
}
